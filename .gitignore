# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/

# PyInstaller build artifacts
/build/
/dist/
*.spec.bak

# Electron app
desktop/node_modules/
desktop/dist/
desktop/out/
*.dmg
*.app

# logs
*.log
npm-debug.log*
yarn-error.log*

# env / secrets
.env
.env.*

# Oyster local data + downloaded definitions
.oyster/
*.icns.tmp

# Icon build intermediate (the .icns/.ico/.png outputs are kept)
branding/Oyster.iconset/

# macOS / editors
.DS_Store
*.swp
.idea/
.vscode/

# Bundled ClamAV is assembled in CI (binaries + DB), not committed
desktop/resources/clamav/*
!desktop/resources/clamav/.gitkeep
