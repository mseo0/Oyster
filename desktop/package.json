{
  "name": "oyster",
  "productName": "Oyster",
  "version": "0.1.3",
  "description": "Oyster — local agentic antivirus that never phones home",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.oyster.antivirus",
    "productName": "Oyster",
    "files": ["electron/**", "renderer/**"],
    "extraResources": [
      { "from": "../dist/oyster-engine", "to": "engine/oyster-engine" },
      { "from": "resources/clamav", "to": "clamav" }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg"],
      "icon": "../branding/Oyster.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Install Oyster",
      "contents": [
        { "x": 140, "y": 200, "type": "file" },
        { "x": 400, "y": 200, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 540, "height": 380 }
    },
    "win": {
      "target": ["nsis"],
      "icon": "../branding/oyster.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Oyster"
    }
  }
}
